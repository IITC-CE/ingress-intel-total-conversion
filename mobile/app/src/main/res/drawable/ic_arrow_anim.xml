<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:name="top"
                android:strokeColor="#FFFFFFFF"
                android:strokeWidth="2"
                android:strokeLineCap="round"
                android:pathData="M4,12 L12,4"/>
            <path
                android:name="middle"
                android:strokeColor="#FFFFFFFF"
                android:strokeWidth="2"
                android:strokeLineCap="round"
                android:pathData="M4,12 L20,12"/>
            <path
                android:name="bottom"
                android:strokeColor="#FFFFFFFF"
                android:strokeWidth="2"
                android:strokeLineCap="round"
                android:pathData="M4,12 L12,20"/>
        </vector>
    </aapt:attr>
    <target android:name="top">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:valueFrom="M4,12 L12,4"
                android:valueTo="M3,7 L21,7"
                android:duration="300"
                android:valueType="pathType"
                android:interpolator="@android:anim/decelerate_interpolator"/>
        </aapt:attr>
    </target>
    <target android:name="middle">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:valueFrom="M4,12 L20,12"
                android:valueTo="M3,12 L21,12"
                android:duration="300"
                android:valueType="pathType"
                android:interpolator="@android:anim/decelerate_interpolator"/>
        </aapt:attr>
    </target>
    <target android:name="bottom">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:valueFrom="M4,12 L12,20"
                android:valueTo="M3,17 L21,17"
                android:duration="300"
                android:valueType="pathType"
                android:interpolator="@android:anim/decelerate_interpolator"/>
        </aapt:attr>
    </target>
</animated-vector>
